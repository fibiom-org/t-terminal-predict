# Optional: seeds the INITIAL JSON-RPC endpoint for the chain named by CHAIN_ID.
# Per-network RPC nodes are otherwise managed inside the app via /settings, and a
# public endpoint is used for each network by default.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: which chain RPC_URL applies to, and the default active network.
# Supported: 1 (Ethereum), 42161 (Arbitrum), 10 (Optimism), 8453 (Base), 137 (Polygon).
CHAIN_ID=1

# Optional execution toggles. /send and /bridge broadcast REAL on-chain
# transactions by default. Set either to 0 to run that flow in simulation mode
# TT_LIVE_SENDS=0
# TT_LIVE_BRIDGES=0

