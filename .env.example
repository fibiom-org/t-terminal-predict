# Optional: seeds the INITIAL JSON-RPC endpoint for the chain named by CHAIN_ID.
# Per-network RPC nodes are otherwise managed inside the app via /settings, and a
# public endpoint is used for each network by default.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: which chain RPC_URL applies to, and the default active network.
# Supported: 1 (Ethereum), 42161 (Arbitrum), 10 (Optimism), 8453 (Base), 137 (Polygon).
CHAIN_ID=1

# Execution toggles and Builder API credentials are now managed in-app via
# /settings → Execution & API, and those saved values take precedence over the
# env vars below. The Builder credentials entered in-app are stored ENCRYPTED
# (AES-256-GCM, same as the seed phrase). The env vars below remain as an
# optional fallback / initial default.

# Optional execution toggles. /send and /bridge /predict broadcast REAL on-chain
# transactions by default. Set either to 0 to run that flow in simulation mode
# You can set them in .env or in the app via /settings → Execution & API.
# TT_LIVE_SENDS=0
# TT_LIVE_BRIDGES=0
# TT_LIVE_BETS=0

# Polymarket Builder API credentials — REQUIRED for live betting (TT_LIVE_BETS=1)
# unless entered in-app. You can set them in .env or in the app via /settings → Execution & API. 
# BUILDER_API_KEY=
# BUILDER_SECRET=
# BUILDER_PASS_PHRASE=
